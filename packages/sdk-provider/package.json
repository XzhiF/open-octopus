{
  "name": "@octopus/sdk-provider",
  "version": "1.0.0",
  "description": "SDK Provider Agent — wraps external API capabilities (e.g. Baidu Map) as agent tools following the pi-agent-core protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/start.ts --format esm,cjs --dts",
    "start": "node dist/start.js",
    "dev": "tsx src/start.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@octopus/shared": "workspace:*",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19",
    "vitest": "^3.2.6"
  }
}
